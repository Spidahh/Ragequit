# Client-side environment variables (Vite)
# Set this to the server URL in production, e.g., https://api.ragequit.example
VITE_SERVER_URL=http://localhost:3000

# Server-side environment variables (Node.js)
# Set this to the client URL in production, e.g., https://ragequit.example
CLIENT_URL=http://localhost:5173

# Optional: additional allowed origins (comma-separated)
ADDITIONAL_ORIGINS=

# Node environment
NODE_ENV=development
PORT=3000
